# Discord bot token
TOKEN=""

# Path to the SQLite database file (use :memory: for sqlite in-memory database)
# docker-compose.yml overrides this
DB_PATH=sqlite:///:memory:

# Comma-separated list of Discord user IDs that have admin privileges
ADMIN_IDS=""

# ID of the Discord guild (server) where the commands will be registered
GUILD_ID=""

# Set to true in development environment, false for production
DEV=false

# Set to true to enable unique job processing (only one user per job at a time)
UNIQUE_JOBS=False
